---
import { InstallWidget } from '../components/code-block/install-widget';
import { DatePickerShowcase } from '../components/DatePickerShowcase';
import '../styles/global.css';
const title = 'temporal-react-datepicker';
const description = 'A high-performance, accessible React date picker built on the JavaScript Temporal API.';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        background: #09090b;
        color: #e4e4e7;
        font-family: 'Inter Variable', 'Inter', system-ui, -apple-system, sans-serif;
        min-height: 100vh;
        -webkit-font-smoothing: antialiased;
      }

      /* ── SKIP LINK ── */
      .skip-link {
        position: absolute;
        top: -100%;
        left: 1rem;
        padding: 0.5rem 1rem;
        background: #fafafa;
        color: #09090b;
        font-size: 0.875rem;
        font-weight: 600;
        text-decoration: none;
        border-radius: 4px;
        z-index: 100;
        transition: top 0.15s;
      }
      .skip-link:focus {
        top: 1rem;
      }

      /* ── FOCUS ── */
      a:focus-visible,
      button:focus-visible {
        outline: 2px solid #fafafa;
        outline-offset: 3px;
        border-radius: 3px;
      }

      /* ── NAV ── */
      nav {
        display: flex;
        align-items: center;
        padding: 0 2rem;
        height: 56px;
        border-bottom: 1px solid #1a1a1a;
        position: sticky;
        top: 0;
        background: #09090b;
        z-index: 10;
      }

      .nav-brand {
        color: #7c7c84;
        font-size: 0.8125rem;
        font-weight: 400;
        font-family: 'JetBrains Mono Variable', 'JetBrains Mono', monospace;
        letter-spacing: 0;
        text-decoration: none;
        transition: color 0.25s cubic-bezier(0.22, 1, 0.36, 1);
        animation: brandSlideIn 0.45s cubic-bezier(0.22, 1, 0.36, 1) both;
      }

      .nav-brand:hover {
        color: #d4d4d8;
      }

      @keyframes brandSlideIn {
        from { opacity: 0; transform: translateX(-10px); }
        to   { opacity: 1; transform: translateX(0); }
      }

      .nav-links {
        margin-left: auto;
        display: flex;
        align-items: center;
        gap: 1.5rem;
        list-style: none;
        padding: 0;
      }

      .nav-links a {
        color: #7c7c84;
        font-size: 0.8125rem;
        text-decoration: none;
        transition: color 0.15s, transform 0.2s cubic-bezier(0.22, 1, 0.36, 1);
      }

      .nav-links a:hover {
        color: #a1a1aa;
        transform: translateY(-1px);
      }

      .nav-links a.nav-pill {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        border: 1px solid #27272a;
        border-radius: 5px;
        padding: 0.25rem 0.75rem;
        color: #7c7c84;
        font-size: 0.75rem;
        font-family: 'JetBrains Mono Variable', 'JetBrains Mono', monospace;
        transform: none;
      }

      .nav-links a.nav-pill:hover {
        border-color: #3f3f46;
        color: #7c7c84;
        transform: none;
      }

      .nav-links a.nav-pill svg {
        flex-shrink: 0;
        fill: currentColor;
      }

      /* ── HERO ── */
      .hero {
        display: flex;
        align-items: flex-start;
        gap: 4rem;
        max-width: 960px;
        margin: 0 auto;
        padding: 6rem 2rem 5rem;
      }

      .hero-left {
        flex: 1;
        min-width: 0;
      }

      .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: #111111;
        border: 1px solid #1e1e1e;
        border-radius: 20px;
        padding: 0.25rem 0.875rem;
        margin-bottom: 1.5rem;
      }

      .hero-badge-dot {
        width: 6px;
        height: 6px;
        background: #52525b;
        border-radius: 50%;
        flex-shrink: 0;
      }

      .hero-badge span {
        color: #7c7c84;
        font-size: 0.6875rem;
        letter-spacing: 0.5px;
      }

      h1 {
        color: #fafafa;
        font-size: clamp(2rem, 5vw, 3rem);
        font-weight: 800;
        letter-spacing: -0.04em;
        line-height: 1.05;
        margin-bottom: 1.25rem;
        text-wrap: balance;
      }

      .hero-tagline {
        color: #7c7c84;
        font-size: 0.9375rem;
        line-height: 1.7;
        margin-bottom: 2rem;
        max-width: 380px;
        text-wrap: pretty;
      }

      .hero-tagline code {
        color: #a1a1aa;
        font-family: 'JetBrains Mono Variable', 'JetBrains Mono', monospace;
        font-size: 0.8125em;
        background: #111111;
        border: 1px solid #27272a;
        padding: 0.1em 0.4em;
        border-radius: 4px;
      }

      .hero-cta {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 1.25rem;
      }

      .btn-primary {
        display: inline-block;
        background: #fafafa;
        color: #09090b;
        font-size: 0.875rem;
        font-weight: 700;
        padding: 0.625rem 1.25rem;
        border-radius: 6px;
        text-decoration: none;
        letter-spacing: -0.2px;
        transition: background 0.15s, transform 0.2s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.2s;
      }

      .btn-primary:hover {
        background: #e4e4e7;
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(250, 250, 250, 0.08);
      }

      .btn-primary:active {
        transform: scale(0.97) translateY(0);
        transition-duration: 0.08s;
      }

      /* ── INSTALL WIDGET (rendered by React component) ── */

      /* ── DATEPICKER SHOWCASE ── */
      .hero-right {
        flex-shrink: 0;
        width: 300px;
      }

      .hero-right-label {
        font-size: 0.625rem;
        font-weight: 500;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        color: #71717a;
        font-family: 'JetBrains Mono Variable', 'JetBrains Mono', monospace;
        margin-bottom: 0.75rem;
      }

      .calendar-preview {
        background: #111111;
        border: 1px solid #1e1e1e;
        border-radius: 6px;
        padding: 1.25rem;
        user-select: none;
      }

      .cal-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1rem;
      }

      .cal-nav {
        color: #27272a;
        font-size: 0.875rem;
        cursor: default;
      }

      .cal-month {
        color: #a1a1aa;
        font-size: 0.8125rem;
        font-weight: 600;
        letter-spacing: -0.2px;
      }

      .cal-grid {
        display: grid;
        grid-template-columns: repeat(7, 1fr);
        text-align: center;
        gap: 2px;
      }

      .cal-weekday {
        color: #27272a;
        font-size: 0.625rem;
        padding: 0.25rem 0;
        text-transform: uppercase;
        letter-spacing: 0.5px;
      }

      .cal-day {
        color: #52525b;
        font-size: 0.75rem;
        padding: 0.375rem 0;
        border-radius: 4px;
        cursor: default;
        line-height: 1;
      }

      .cal-day.empty {
        color: transparent;
      }

      .cal-day.today {
        color: #fafafa;
        position: relative;
      }

      .cal-day.today::after {
        content: '';
        position: absolute;
        bottom: 2px;
        left: 50%;
        transform: translateX(-50%);
        width: 3px;
        height: 3px;
        background: #fafafa;
        border-radius: 50%;
      }

      .cal-day.selected {
        background: #fafafa;
        color: #09090b;
        font-weight: 700;
      }

      /* ── FEATURE STRIP ── */
      .features {
        border-top: 1px solid #111111;
        border-bottom: 1px solid #111111;
        max-width: 960px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: repeat(4, 1fr);
      }

      .feature {
        padding: 1.25rem 1.5rem;
        border-right: 1px solid #111111;
      }

      .feature:last-child {
        border-right: none;
      }

      .feature-label {
        color: #7c7c84;
        font-size: 0.625rem;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        font-weight: 500;
        margin-bottom: 0.375rem;
      }

      .feature-text {
        color: #7c7c84;
        font-size: 0.75rem;
        line-height: 1.5;
      }

      /* ── KEYFRAMES ── */
      @keyframes fadeSlideUp {
        from { opacity: 0; transform: translateY(14px); }
        to   { opacity: 1; transform: translateY(0); }
      }

      @keyframes fadeIn {
        from { opacity: 0; }
        to   { opacity: 1; }
      }

      @keyframes pulseDot {
        0%, 100% { opacity: 1; transform: scale(1); }
        50%       { opacity: 0.25; transform: scale(2); }
      }


      /* ── HERO ENTRANCE ── */
      .hero-badge   { animation: fadeSlideUp 0.45s cubic-bezier(0.22, 1, 0.36, 1) both; }
      h1            { animation: fadeSlideUp 0.5s  0.07s cubic-bezier(0.22, 1, 0.36, 1) both; }
      .hero-tagline { animation: fadeSlideUp 0.5s  0.14s cubic-bezier(0.22, 1, 0.36, 1) both; }
      .hero-cta     { animation: fadeSlideUp 0.5s  0.22s cubic-bezier(0.22, 1, 0.36, 1) both; }
      .hero-right   { animation: fadeIn      0.55s 0.30s cubic-bezier(0.22, 1, 0.36, 1) both; }

      /* ── BADGE DOT PULSE ── */
      .hero-badge-dot {
        animation: pulseDot 2.8s 1s ease-in-out infinite;
      }

      /* ── FEATURE STRIP ENTRANCE ── */
      .feature { animation: fadeSlideUp 0.4s cubic-bezier(0.22, 1, 0.36, 1) both; }
      .feature:nth-child(1) { animation-delay: 0.44s; }
      .feature:nth-child(2) { animation-delay: 0.50s; }
      .feature:nth-child(3) { animation-delay: 0.56s; }
      .feature:nth-child(4) { animation-delay: 0.62s; }

      /* ── REDUCED MOTION ── */
      @media (prefers-reduced-motion: reduce) {
        *, *::before, *::after {
          animation-duration: 0.01ms !important;
          animation-iteration-count: 1 !important;
          transition-duration: 0.01ms !important;
        }
      }

      /* ── RESPONSIVE ── */
      @media (max-width: 768px) {
        .hero {
          flex-direction: column;
          gap: 2.5rem;
          padding: 3.5rem 1.5rem 3rem;
        }

        .hero-right {
          width: 100%;
        }

        .calendar-preview {
          max-width: 300px;
          margin: 0 auto;
        }

        .features {
          grid-template-columns: repeat(2, 1fr);
        }

        .feature:nth-child(2) {
          border-right: none;
        }

        .feature:nth-child(3) {
          border-right: 1px solid #111111;
        }
      }

      @media (max-width: 480px) {
        nav { padding: 0 1.25rem; }

        .nav-links { gap: 0.75rem; }

        .features {
          grid-template-columns: 1fr;
        }

        .feature {
          border-right: none;
          border-bottom: 1px solid #111111;
        }

        .feature:last-child {
          border-bottom: none;
        }
      }

      /* ── VERY SMALL SCREENS (≤360px) ── */
      @media (max-width: 360px) {
        /* Hide text-only nav links — keep only the external pills */
        .nav-links li:nth-child(-n+2) { display: none; }

        .hero {
          padding: 2.5rem 1.25rem 2.5rem;
          gap: 2rem;
        }
      }
    </style>
  </head>
  <body>

    <a href="#main-content" class="skip-link">Skip to content</a>

    <!-- NAV -->
    <nav aria-label="Site navigation">
      <a href={`${base}/`} class="nav-brand">temporal-react-datepicker</a>
      <ul class="nav-links">
        <li><a href={`${base}/guides/getting-started/`}>Guides</a></li>
        <li><a href={`${base}/reference/props/`}>Reference</a></li>
        <li>
          <a
            href="https://github.com/PabloViniegra/temporal-react-datepicker-docs"
            target="_blank"
            rel="noopener noreferrer"
            class="nav-pill"
            aria-label="GitHub repository (opens in new tab)"
          ><svg width="13" height="13" viewBox="0 0 16 16" aria-hidden="true"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8z"/></svg>GitHub<span aria-hidden="true"> ↗</span></a>
        </li>
        <li>
          <a
            href="https://www.npmjs.com/package/temporal-react-datepicker"
            target="_blank"
            rel="noopener noreferrer"
            class="nav-pill"
            aria-label="npm package (opens in new tab)"
          >npm<span aria-hidden="true"> ↗</span></a>
        </li>
      </ul>
    </nav>

    <!-- MAIN CONTENT -->
    <main id="main-content">

    <!-- HERO -->
    <section class="hero" aria-label="Overview">
      <div class="hero-left">
        <div class="hero-badge">
          <span class="hero-badge-dot" aria-hidden="true"></span>
          <span>Built on Temporal API</span>
        </div>

        <h1>The date picker<br />the web deserves</h1>

        <p class="hero-tagline">
          Immutable <code>Temporal.PlainDate</code> logic.
          Accessible by default. Zero legacy Date objects.
        </p>

        <div class="hero-cta">
          <a href={`${base}/guides/getting-started/`} class="btn-primary">Get Started →</a>

          <InstallWidget client:only="react" />
        </div>
      </div>

      <!-- Interactive datepicker showcase -->
      <div class="hero-right">
        <p class="hero-right-label" aria-hidden="true">Live preview</p>
        <DatePickerShowcase client:only="react" />
      </div>
    </section>

    <!-- FEATURE STRIP -->
    <section class="features" aria-label="Features">
      <div class="feature">
        <div class="feature-label">Temporal API</div>
        <div class="feature-text">Immutable PlainDate. No timezone bugs.</div>
      </div>
      <div class="feature">
        <div class="feature-label">Accessible</div>
        <div class="feature-text">Full keyboard nav. ARIA grid roles.</div>
      </div>
      <div class="feature">
        <div class="feature-label">Themeable</div>
        <div class="feature-text">17 CSS tokens. Dark + light auto.</div>
      </div>
      <div class="feature">
        <div class="feature-label">i18n</div>
        <div class="feature-text">BCP 47 locale. Full labels override.</div>
      </div>
    </section>

    </main>

  </body>
</html>
